// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// -----------------------------------------------------------------------------
// ENUMS
// -----------------------------------------------------------------------------

enum JobApplicationStatus {
  SAVED
  APPLIED
  INTERVIEWING
  OFFER_RECEIVED
  REJECTED
  WITHDRAWN
  GHOSTED
}

enum WorkMode {
  REMOTE
  HYBRID
  ON_SITE
}

enum CompensationType {
  HOURLY
  MONTHLY
  ANNUAL
  PROJECT_BASED
}

// Use a String for currency instead of enum for maximum flexibility, 
// as currencies can change and supporting 150+ ISO codes in an enum is overkill.

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
  FREELANCE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum InterviewType {
  SCREENING
  HR
  TECHNICAL
  CULTURAL
  BEHAVIORAL
  CASE_STUDY
  FINAL
  OTHER
}

enum InterviewStatus {
  SCHEDULED
  COMPLETED
  CANCELED
  RESCHEDULED
  NO_SHOW
}

enum ReminderType {
  FOLLOW_UP
  INTERVIEW_PREP
  APPLICATION_DEADLINE
  TASK
  OTHER
}

enum ReminderStatus {
  PENDING
  COMPLETED
  CANCELED
}

// -----------------------------------------------------------------------------
// MODELS
// -----------------------------------------------------------------------------

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  passwordHash    String
  firstName       String
  lastName        String
  
  // Opcionales
  country         String? // Ejemplo: "US", "AR", "ES" (ISO 3166-1 alpha-2 recomendado)
  phone           String?
  avatarUrl       String?
  timezone        String? // Ejemplo: "America/New_York"
  language        String? // Ejemplo: "en", "es"
  isActive        Boolean   @default(true)
  emailVerifiedAt DateTime?
  lastLoginAt     DateTime?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relaciones
  resumes         Resume[]
  resumeVariants  ResumeVariant[]
  jobApplications JobApplication[]
  interviews      Interview[]
  reminders       Reminder[]

  @@index([email])
}

model Resume {
  id           String    @id @default(uuid())
  userId       String
  title        String    // Ejemplo: "Software Engineer - Backend"
  slug         String?   // Útil si hay URL pública (ej. myapp.com/u/dgo34/resume-slug)
  summary      String?   @db.Text
  content      Json?     // Contenido estructurado: experiencia, educación, skills
  template     String?   // Ejemplo: "modern", "classic"
  isDefault    Boolean   @default(false)
  
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  variants     ResumeVariant[]

  @@index([userId])
}

model ResumeVariant {
  id               String    @id @default(uuid())
  resumeId         String
  userId           String
  
  title            String    // Nombre de esta variante, ej: "Google - Senior GO Developer"
  content          Json?     // CV modificado y adaptado a esta vacante
  notes            String?   @db.Text
  generatedWithAI  Boolean   @default(false)
  atsScore         Float?    // Rango 0 a 100 evaluado por IA u otra tool
  matchScore       Float?    
  pdfUrl           String?   // Referencia al PDF exportado en un storage como S3
  
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume           Resume    @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  
  // Relación opcional
  jobApplications  JobApplication[]

  @@index([userId])
  @@index([resumeId])
}

model JobApplication {
  id                    String    @id @default(uuid())
  userId                String
  resumeVariantId       String?   // Qué CV se usó para esta vacante
  
  // Datos del trabajo
  title                 String
  company               String
  description           String?   @db.Text
  jobUrl                String?
  source                String?   // "LinkedIn", "Computrabajo", "Referral", "Company Website"
  location              String?
  country               String?
  workMode              WorkMode  @default(REMOTE)
  employmentType        EmploymentType?
  seniorityLevel        String?   // Ej: Junior, Mid, Senior, Lead
  
  // Compensación y Beneficios
  compensationAmountMin Float?
  compensationAmountMax Float?
  compensationType      CompensationType?
  currency              String?   // Ej: "USD", "EUR" (string es más flexible aquí)
  benefits              String?   @db.Text // o Json si estructuramos beneficios
  
  // Estado y seguimiento
  status                JobApplicationStatus @default(SAVED)
  priority              Priority? @default(MEDIUM)
  
  appliedAt             DateTime?
  savedAt               DateTime? @default(now())
  closedAt              DateTime? // Cuando se cerró/rechazó/archivó
  notes                 String?   @db.Text
  
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Relaciones
  user                  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  resumeVariant         ResumeVariant?   @relation(fields: [resumeVariantId], references: [id], onDelete: SetNull)
  interviews            Interview[]
  reminders             Reminder[]

  @@index([userId])
  @@index([status])
  @@index([company]) // Útil para buscar si ya se aplicó antes a la misma empresa
}

model Interview {
  id               String    @id @default(uuid())
  userId           String
  jobApplicationId String
  
  type             InterviewType
  status           InterviewStatus @default(SCHEDULED)
  scheduledAt      DateTime
  durationMinutes  Int?
  timezone         String?
  location         String?   // Presencial
  meetingUrl       String?   // Remoto (Zoom, Meet)
  
  interviewerName  String?
  interviewerEmail String?
  
  notes            String?   @db.Text
  feedback         String?   @db.Text
  
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relaciones
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobApplication   JobApplication @relation(fields: [jobApplicationId], references: [id], onDelete: Cascade)
  
  reminders        Reminder[]

  @@index([userId])
  @@index([jobApplicationId])
  @@index([scheduledAt]) // Para ordenar próximas entrevistas
}

model Reminder {
  id               String    @id @default(uuid())
  userId           String
  jobApplicationId String?
  interviewId      String?
  
  title            String
  description      String?   @db.Text
  type             ReminderType
  status           ReminderStatus @default(PENDING)
  
  dueAt            DateTime
  completedAt      DateTime?
  isRecurring      Boolean   @default(false)
  
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relaciones
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobApplication   JobApplication? @relation(fields: [jobApplicationId], references: [id], onDelete: Cascade)
  interview        Interview?     @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([dueAt]) // Útil para traer recordatorios próximos
  @@index([status, dueAt]) // Útil para traer pendientes próximos
}
