// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// -----------------------------------------------------------------------------
// ENUMS
// -----------------------------------------------------------------------------

enum Role {
  USER
  ADMIN
}

enum JobApplicationStatus {
  SAVED
  APPLIED
  INTERVIEWING
  OFFER_RECEIVED
  REJECTED
  WITHDRAWN
  GHOSTED
}

enum WorkMode {
  REMOTE
  HYBRID
  ON_SITE
}

enum CompensationType {
  HOURLY
  MONTHLY
  ANNUAL
  PROJECT_BASED
}

// Use a String for currency instead of enum for maximum flexibility, 
// as currencies can change and supporting 150+ ISO codes in an enum is overkill.

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
  FREELANCE
}

enum ContractType {
  UNDEFINED
  FIXED_TERM
  PROJECT_BASED
  CONTRACTOR
  OTHER
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum InterviewType {
  SCREENING
  HR
  TECHNICAL
  CULTURAL
  BEHAVIORAL
  CASE_STUDY
  FINAL
  OTHER
}

enum InterviewStatus {
  SCHEDULED
  COMPLETED
  CANCELED
  RESCHEDULED
  NO_SHOW
}

enum ReminderType {
  FOLLOW_UP
  INTERVIEW_PREP
  APPLICATION_DEADLINE
  TASK
  OTHER
}

enum ReminderStatus {
  PENDING
  COMPLETED
  CANCELED
}

// -----------------------------------------------------------------------------
// MODELS
// -----------------------------------------------------------------------------

model Profile {
  id        String  @id @default(uuid())
  email     String  @unique
  role      Role    @default(USER)
  enabled   Boolean @default(true)
  document  String?
  firstName String?
  lastName  String?

  // Opcionales
  country     String?
  phone       String?
  avatarUrl   String?
  timezone    String?
  language    String?
  lastLoginAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  resumes         Resume[]
  resumeVariants  ResumeVariant[]
  jobApplications JobApplication[]
  interviews      Interview[]
  reminders       Reminder[]

  @@index([email])
}

model Resume {
  id        String  @id @default(uuid())
  profileId String
  title     String
  slug      String?
  template  String?
  isDefault Boolean @default(false)

  // Estructura Base del CV
  resumeName   String
  personalInfo Json
  summary      String? @db.Text
  education    Json
  experience   Json
  projects     Json?
  skills       Json?
  others       Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile  Profile         @relation(fields: [profileId], references: [id], onDelete: Cascade)
  variants ResumeVariant[]

  @@index([profileId])
}

model ResumeVariant {
  id        String @id @default(uuid())
  resumeId  String
  profileId String

  title String

  // Copia de la Estructura Base del CV (Modificable)
  resumeName   String
  personalInfo Json
  summary      String? @db.Text
  education    Json
  experience   Json
  projects     Json?
  skills       Json?
  others       Json?

  // Novedades para Variante
  modifications   Json? // Log de las modificaciones hechas por IA (ej. en experience)
  notes           String? @db.Text
  generatedWithAI Boolean @default(false)
  atsScore        Float?
  matchScore      Float?
  pdfUrl          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  resume  Resume  @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  jobApplications JobApplication[]

  @@index([profileId])
  @@index([resumeId])
}

model JobApplication {
  id              String  @id @default(uuid())
  profileId       String
  resumeVariantId String?

  // Datos del trabajo
  title          String
  company        String
  description    String?         @db.Text
  jobUrl         String?
  source         String?
  location       String?
  country        String?
  workMode       WorkMode        @default(REMOTE)
  employmentType EmploymentType?
  contractType   ContractType?
  seniorityLevel String?

  // Compensación y Beneficios
  compensationAmountMin Float?
  compensationAmountMax Float?
  compensationType      CompensationType?
  currency              String?
  benefits              String?           @db.Text

  // Estado y seguimiento
  status   JobApplicationStatus @default(SAVED)
  priority Priority?            @default(MEDIUM)

  appliedAt DateTime?
  savedAt   DateTime? @default(now())
  closedAt  DateTime? // Cuando se cerró/rechazó/archivó
  notes     String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile       Profile        @relation(fields: [profileId], references: [id], onDelete: Cascade)
  resumeVariant ResumeVariant? @relation(fields: [resumeVariantId], references: [id], onDelete: SetNull)
  interviews    Interview[]
  reminders     Reminder[]

  @@index([profileId])
  @@index([status])
  @@index([company]) // Útil para buscar si ya se aplicó antes a la misma empresa
}

model Interview {
  id               String @id @default(uuid())
  profileId        String
  jobApplicationId String

  type            InterviewType
  status          InterviewStatus @default(SCHEDULED)
  scheduledAt     DateTime
  durationMinutes Int?
  timezone        String?
  location        String? // Presencial
  meetingUrl      String? // Remoto (Zoom, Meet)

  interviewerName  String?
  interviewerEmail String?

  notes    String? @db.Text
  feedback String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  profile        Profile        @relation(fields: [profileId], references: [id], onDelete: Cascade)
  jobApplication JobApplication @relation(fields: [jobApplicationId], references: [id], onDelete: Cascade)

  reminders Reminder[]

  @@index([profileId])
  @@index([jobApplicationId])
  @@index([scheduledAt]) // Para ordenar próximas entrevistas
}

model Reminder {
  id               String  @id @default(uuid())
  profileId        String
  jobApplicationId String?
  interviewId      String?

  title       String
  description String?        @db.Text
  type        ReminderType
  status      ReminderStatus @default(PENDING)

  dueAt       DateTime
  completedAt DateTime?
  isRecurring Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  profile        Profile         @relation(fields: [profileId], references: [id], onDelete: Cascade)
  jobApplication JobApplication? @relation(fields: [jobApplicationId], references: [id], onDelete: Cascade)
  interview      Interview?      @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@index([dueAt]) // Útil para traer recordatorios próximos
  @@index([status, dueAt]) // Útil para traer pendientes próximos
}
